    {
      "parameters": {
        "jsCode": "return items.map(item => {\n    const output = item.json.output || \"\";\n    \n    // Extraction du DIAGNOSTIC : cherche tout ce qui se trouve entre \"DIAGNOSTIC :\" et \"ACTION :\"\n    const diagMatch = output.match(/DIAGNOSTIC\\s*:\\s*([^]*?)(?=\\nACTION|$)/i);\n    // Extraction de l'ACTION : cherche tout ce qui se trouve après \"ACTION :\"\n    const actionMatch = output.match(/ACTION\\s*:\\s*([^]*?)$/i);\n\n    // Nettoyage des caractères inutiles\n    const diagnostic = diagMatch ? diagMatch[1].replace(/[\\[\\]]/g, '').trim() : \"Non spécifié\";\n    const action = actionMatch ? actionMatch[1].replace(/[\\[\\]]/g, '').trim() : \"Aucune action définie\";\n\n    // Récupération de la date (s'assure de prendre la valeur du Sheets ou de l'IA)\n    const dateEvent = item.json.Date || \"Date inconnue\";\n\n    // Construction du message Telegram formaté avec la DATE\n    const telegramMessage = `🚨 *ALERTE ANOMALIE DÉTECTÉE* 🚨\\n\\n` +\n                            `📅 *Date :* ${dateEvent}\\n` +\n                            `📍 *Machine :* ${item.json.Machine_ID || \"N/A\"}\\n` +\n                            `📊 *KPI Critique :* OEE ${item.json.OEE_Calcule || item.json[\"OEE_Calcule \"]}%\\n\\n` +\n                            `🔍 *DIAGNOSTIC TECHNIQUE :*\\n${diagnostic}\\n\\n` +\n                            `✅ *PLAN D'ACTION (PDCA) :*\\n${action}\\n\\n` +\n                            `🕒 _Statut mis à jour dans le Dashboard_`;\n\n    return {\n        json: {\n            ...item.json,\n            formatted_message: telegramMessage\n        }\n    };\n});"
      },
