      "parameters": {
        "jsCode": "for (const item of items) {\n  const piecesProduites = item.json.Pieces_Produites;\n  const piecesDefectueuses = item.json.Pieces_Defectueuses;\n\n  // Calcul du taux de défaut\n  item.json.Taux_Defaut = ((piecesDefectueuses / piecesProduites) * 100).toFixed(2);\n\n  // Préparation du message pour l'IA\n  item.json.Context_IA = `Alerte sur la machine ${item.json.Machine_ID}. OpID: ${item.json[\"OpID\"]},  OEE: ${item.json[\"OEE_Calcule \"]}%, Taux de défaut: ${item.json.Taux_Defaut}%, Temps d'arrêt: ${item.json[\"Temps_Arret \"]} min, Date :${item.json[\"Date\"]} `;\n}\nreturn items;"
      },
