    {
      "parameters": {
        "jsCode": "return items.map(item => {\n    const aiOutput = item.json.output || \"\";\n    let parsedData = {};\n\n    try {\n        // 1. Tenter d'extraire le bloc JSON entre les premières accolades { }\n        const jsonMatch = aiOutput.match(/\\{[\\s\\S]*?\\}/);\n        \n        if (jsonMatch) {\n            parsedData = JSON.parse(jsonMatch[0]);\n        } else {\n            // 2. Fallback : Si le JSON est mal formé, on utilise les Regex (sécurité)\n            const statusMatch = aiOutput.match(/STATUT\\s*:\\s*(ANOMALIE|NORMALE)/i);\n            const diagMatch = aiOutput.match(/DIAGNOSTIC\\s*:\\s*([^]*?)(?=\\nACTION|$)/i);\n            const actionMatch = aiOutput.match(/ACTION\\s*:\\s*([^]*?)$/i);\n\n            parsedData = {\n                \"STATUT\": statusMatch ? statusMatch[1].toUpperCase() : \"INCONNU\",\n                \"DIAGNOSTIC\": diagMatch ? diagMatch[1].trim() : \"Non spécifié\",\n                \"ACTION\": actionMatch ? actionMatch[1].trim() : \"Non spécifié\"\n            };\n        }\n    } catch (e) {\n        console.error(\"Erreur de parsing JSON sur un item\");\n    }\n\n    // 3. Définition des indicateurs visuels pour le Dashboard\n    const isAnomaly = parsedData.STATUT === \"ANOMALIE\";\n    const labelStatus = isAnomaly ? \"🔴 ANOMALIE\" : \"🟢 NORMAL\";\n\n    // 4. Retourne l'item enrichi avec toutes les clés extraites incluant la Date\n    return {\n        json: {\n            ...item.json, // On garde les données d'origine (row_number, etc.)\n            STATUT: parsedData.STATUT,\n            DIAGNOSTIC: parsedData.DIAGNOSTIC,\n            ACTION: parsedData.ACTION,\n            status_final: labelStatus,\n            is_anomaly: isAnomaly,\n            // Mapping des métadonnées et KPI (priorité au JSON de l'IA, sinon données d'origine)\n            OpID: parsedData.OpID || item.json.OpID,\n            Date: parsedData.Date || item.json.Date,\n            Machine_ID: parsedData.Machine_ID || item.json.Machine_ID,\n            OEE_Calcule: parsedData.OEE_Calcule || item.json.OEE_Calcule,\n            Taux_Defaut: parsedData.Taux_Defaut || item.json.Taux_Defaut\n        }\n    };\n});"
      },
